# Copie para .env e preencha. Não commite .env.
# O projeto usa apenas Supabase (PostgreSQL); não há banco local.

# Supabase - Connection strings (URI)
# Supabase > Settings > Database > Connection string
# Senha: # = %23, @ = %40
# App: Transaction pooler (porta 6543) - use no Next.js
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[SENHA]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Migrations: Direct connection (Dashboard > Database > URI - Direct) - evita erro prepared statement
DIRECT_URL="postgresql://postgres:[SENHA]@db.[PROJECT_REF].supabase.co:5432/postgres"

# NextAuth
# Gere um secret forte: openssl rand -base64 32
NEXTAUTH_SECRET="gere-um-secret-forte"
# Desenvolvimento: http://localhost:3000
# Produção: URL pública com HTTPS (ex.: https://seu-dominio.com)
NEXTAUTH_URL="http://localhost:3000"

# Resend (recuperação de senha por e-mail)
# Crie conta em https://resend.com e gere uma API Key. Plano gratuito: 100 e-mails/dia.
RESEND_API_KEY="re_xxxx"
# E-mail remetente (domínio verificado no Resend ou use onboarding@resend.dev para testes)
RESEND_FROM_EMAIL="noreply@seudominio.com"
